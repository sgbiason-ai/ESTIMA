rules_version = '2';

// Firebase Storage rules
// Arborescence :
//   companies/{companyId}/crr/{crrId}/{obsId}/{fileName}            → photos d'observations CRC
//   companies/{companyId}/site_visits/{visitId}/{obsId}/{fileName}  → photos d'observations Visites de site
//
// Securite multi-tenant :
// - Ecriture : auth requise + verification taille + content-type
// - Lecture : publique (necessaire car les <img src> ne portent pas le token d'auth
//   Firebase, et depuis 2026 le download URL token Storage ne bypass plus les rules).
//   Securite assuree par l'imprevisibilite des paths (companyId / crrId / obsId / fileName
//   contiennent tous des UUIDs non-devinables, non-listables, non-indexes).
// - Limite taille : 5 Mo par image (les photos compressees font ~30-150 Ko)
// - Content-type : image/* uniquement

service firebase.storage {
  match /b/{bucket}/o {

    // Photos CRC
    // Lecture publique : les <img src=...> doivent pouvoir charger sans auth.
    // Le cloisonnement multi-tenant est garanti par l'imprevisibilite des paths
    // (4 segments d'UUIDs random) et l'absence de listing public.
    // ⚠️ NE JAMAIS ajouter firestore.get() ici : les regles Cloud Storage ne
    // peuvent pas lire Firestore de facon fiable (IAM cross-service non garanti
    // sur Blaze) → storage/unauthorized, upload casse. Deja retire en avril
    // (commit 6c5ee5d), re-introduit puis re-retire. L'ownership « createur
    // uniquement » se garantit cote Firestore rules + app, pas ici.
    match /companies/{companyId}/crr/{crrId}/{obsId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Photos Visites de site (meme modele de securite que le CRC)
    // Lecture publique : les <img src=...> doivent charger sans auth.
    // Cloisonnement garanti par l'imprevisibilite des paths (UUIDs random).
    // ⚠️ Meme regle que le CRC : PAS de firestore.get() (cross-service casse
    // l'upload → storage/unauthorized). Cf. commentaire du bloc CRC ci-dessus.
    match /companies/{companyId}/site_visits/{visitId}/{obsId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Bloquer tout le reste par defaut
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
