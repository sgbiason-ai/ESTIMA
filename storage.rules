rules_version = '2';

// Firebase Storage rules
// Arborescence :
//   companies/{companyId}/crr/{crrId}/{obsId}/{fileName}  → photos d'observations CRC
//
// Securite multi-tenant :
// - Ecriture : verifie que le user appartient bien a la company via Firestore
// - Lecture : auth requise (URL avec token = non listable sans connaissance du path)
// - Limite taille : 5 Mo par image (les photos compressees font ~30-150 Ko)
// - Content-type : image/* uniquement

service firebase.storage {
  match /b/{bucket}/o {

    // Profil user Firestore du caller
    function userCompanyId() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.companyId;
    }

    // Photos CRC
    match /companies/{companyId}/crr/{crrId}/{obsId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && userCompanyId() == companyId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
                    && userCompanyId() == companyId;
    }

    // Bloquer tout le reste par defaut
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
