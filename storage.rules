rules_version = '2';

// Firebase Storage rules
// Arborescence :
//   companies/{companyId}/crr/{crrId}/{obsId}/{fileName}  → photos d'observations CRC
//
// Securite multi-tenant :
// - Ecriture : verifie que le user appartient bien a la company via Firestore
// - Lecture : auth requise (URL avec token = non listable sans connaissance du path)
// - Limite taille : 5 Mo par image (les photos compressees font ~30-150 Ko)
// - Content-type : image/* uniquement

service firebase.storage {
  match /b/{bucket}/o {

    // Photos CRC
    // Securite : auth requise + size + content-type. Le cloisonnement
    // multi-tenant est garanti cote client par le path derive du companyId
    // du user (lui-meme valide par les Firestore rules sur /companies/{id}/crr).
    // Les URLs Storage incluent un token non-devinable (pas de listing public).
    match /companies/{companyId}/crr/{crrId}/{obsId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }

    // Bloquer tout le reste par defaut
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
