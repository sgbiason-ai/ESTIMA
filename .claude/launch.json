    },
    {
      "name": "Chronos Dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "C:/Projet/Chronos", "run", "dev", "--", "--port", "5182", "--strictPort"],
      "port": 5182,
      "autoPort": false
    }
  ]
