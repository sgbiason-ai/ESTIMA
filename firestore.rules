rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────

    // Returns the authenticated user's profile document
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // True if the caller belongs to the given company
    function isCompanyMember(companyId) {
      return request.auth != null && getUserData().companyId == companyId;
    }

    // True if the caller is an admin of the given company
    function isCompanyAdmin(companyId) {
      return isCompanyMember(companyId) && getUserData().isAdmin == true;
    }

    // True if the caller is a super-admin (isAdmin flag on their profile)
    function isSuperAdmin() {
      return request.auth != null && getUserData().isAdmin == true;
    }

    // True if the incoming write does NOT touch the isAdmin field
    function doesNotModifyAdminField() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']);
    }

    // ─── Block everything by default ────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── User profiles (/users/{uid}) ───────────────────────────────
    match /users/{uid} {
      // Super-admins can list/read all user profiles (module Administration)
      allow read: if isSuperAdmin();

      // Users can read their own profile
      allow read: if request.auth != null && request.auth.uid == uid;

      // Users can update their own profile BUT cannot change isAdmin
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && doesNotModifyAdminField();

      // Only a superadmin (someone already flagged isAdmin in the same
      // company) can create or fully update user docs (including isAdmin)
      allow create: if request.auth != null
                    && getUserData().isAdmin == true
                    && getUserData().companyId == request.resource.data.companyId;

      // Admins of the same company can read any member profile
      allow read: if request.auth != null
                  && resource.data.companyId != null
                  && isCompanyAdmin(resource.data.companyId);

      // Admins of the same company can write any member profile
      // (including toggling isAdmin)
      allow update: if request.auth != null
                    && resource.data.companyId != null
                    && isCompanyAdmin(resource.data.companyId);
    }

    // ─── Company documents (/companies/{companyId}) ─────────────────
    match /companies/{companyId} {
      // Super-admins can list/read all companies (module Administration)
      allow read: if isSuperAdmin();

      // All company members can read
      allow read: if isCompanyMember(companyId);

      // Only company admins can write
      allow write: if isCompanyAdmin(companyId);

      // ─── Sub-collections ────────────────────────────────────────
      // projects, bpu, categories, units, resources
      // Readable and writable by all members of the company
      match /projects/{projectId} {
        allow read, write: if isCompanyMember(companyId);

        // Audit trail — lecture seule pour les membres, écriture par le système
        match /history/{entryId} {
          allow read: if isCompanyMember(companyId);
          allow create: if isCompanyMember(companyId);
          allow update, delete: if false;
        }

        // Archives de projets
        match /archives/{archiveId} {
          allow read, write: if isCompanyMember(companyId);
        }
      }

      match /bpu/{itemId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyMember(companyId)
                     && request.resource.data.keys().hasAll(['designation', 'unit', 'price'])
                     && request.resource.data.price is number;
      }

      match /categories/{catId} {
        allow read, write: if isCompanyMember(companyId);
      }

      match /units/{unitId} {
        allow read, write: if isCompanyMember(companyId);
      }

      match /resources/{resId} {
        allow read, write: if isCompanyMember(companyId);
      }

      // Dossiers de classement des projets
      match /folders/{folderId} {
        allow read, write: if isCompanyMember(companyId);
      }

      // Comptes rendus de chantier (CRC/CRR)
      match /crr/{crrId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyMember(companyId);
      }

      // Devis MOE — lecture membres, écriture admins uniquement
      match /devisMoe/{devisId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyAdmin(companyId);
      }

      // Fiches marché (Documents Administratifs)
      match /fichesMarche/{ficheId} {
        allow read, write: if isCompanyMember(companyId);
      }

      // Présence en temps réel
      match /presence/{presenceId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyMember(companyId)
                     && request.auth.uid == presenceId;
      }
    }
  }
}
