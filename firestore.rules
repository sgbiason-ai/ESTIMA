rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────

    // Returns the authenticated user's profile document
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // True si le caller est authentifié ET possède un doc /users/{uid}.
    // Garde indispensable : sans elle, getUserData() lève une erreur quand le
    // profil n'existe pas encore, ce qui fait échouer TOUTE la règle en
    // permission-denied — y compris la lecture par l'utilisateur de son propre
    // profil (bootstrap de l'app, useAppAuth). Le && court-circuite donc
    // getUserData() n'est appelé que si le doc existe.
    function userExists() {
      return request.auth != null
             && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // True if the caller belongs to the given company
    function isCompanyMember(companyId) {
      return userExists() && getUserData().companyId == companyId;
    }

    // True if the caller is an admin of the given company
    function isCompanyAdmin(companyId) {
      return isCompanyMember(companyId) && getUserData().isAdmin == true;
    }

    // True if the caller is a super-admin (isAdmin flag on their profile)
    function isSuperAdmin() {
      return userExists() && getUserData().isAdmin == true;
    }

    // True if the caller is the application-level super-admin (by email).
    // Used for cross-tenant operations like creating new companies.
    function isAppSuperAdmin() {
      return request.auth != null
             && request.auth.token.email == 'samuel.biason@papyrus-be.fr';
    }

    // True if the incoming write does NOT touch the isAdmin field
    function doesNotModifyAdminField() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']);
    }

    // ─── Block everything by default ────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─── User profiles (/users/{uid}) ───────────────────────────────
    match /users/{uid} {
      // Super-admins can list/read all user profiles (module Administration)
      allow read: if isSuperAdmin();

      // Users can read their own profile
      allow read: if request.auth != null && request.auth.uid == uid;

      // Users can update their own profile BUT cannot change isAdmin
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && doesNotModifyAdminField();

      // Only a superadmin (someone already flagged isAdmin in the same
      // company) can create or fully update user docs (including isAdmin)
      allow create: if request.auth != null
                    && getUserData().isAdmin == true
                    && getUserData().companyId == request.resource.data.companyId;

      // Admins of the same company can read any member profile
      allow read: if request.auth != null
                  && resource.data.companyId != null
                  && isCompanyAdmin(resource.data.companyId);

      // Admins of the same company can write any member profile
      // (including toggling isAdmin)
      allow update: if request.auth != null
                    && resource.data.companyId != null
                    && isCompanyAdmin(resource.data.companyId);

      // Application super-admin can create / update / delete any user doc
      // (cross-tenant assignment from the Administration module)
      allow create, update, delete: if isAppSuperAdmin();

      // Préférences utilisateur (dernier projet/chantier/fiche/devis/visite par module)
      // Lecture et écriture réservées au propriétaire uniquement.
      match /preferences/{prefId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Données privées (ex: mot de passe SMTP chiffré).
      // Aucun accès direct côté client — seules les Cloud Functions (admin SDK) y accèdent.
      match /private/{docId} {
        allow read, write: if false;
      }
    }

    // ─── Company documents (/companies/{companyId}) ─────────────────
    match /companies/{companyId} {
      // Super-admins can list/read all companies (module Administration)
      allow read: if isSuperAdmin();

      // All company members can read
      allow read: if isCompanyMember(companyId);

      // Only company admins can write
      allow write: if isCompanyAdmin(companyId);

      // Application super-admin can create / delete companies (cross-tenant)
      allow create, delete: if isAppSuperAdmin();

      // ─── Sub-collections ────────────────────────────────────────
      // projects, bpu, categories, units, resources
      // Readable and writable by all members of the company
      match /projects/{projectId} {
        allow read, write: if isCompanyMember(companyId);

        // Audit trail — lecture seule pour les membres, écriture par le système
        match /history/{entryId} {
          allow read: if isCompanyMember(companyId);
          allow create: if isCompanyMember(companyId);
          allow update, delete: if false;
        }

        // Archives de projets
        match /archives/{archiveId} {
          allow read, write: if isCompanyMember(companyId);
        }

        // Analyse des prix — document dédié
        match /analysis/{docId} {
          allow read, write: if isCompanyMember(companyId);
        }

        // Rapport d'analyse des offres — document dédié
        match /rao/{docId} {
          allow read, write: if isCompanyMember(companyId);
        }

        // Contenu des documents par projet (CCTP / RC / CCAP) — document dédié
        match /cctp/{docId} {
          allow read, write: if isCompanyMember(companyId);
        }
        match /rc/{docId} {
          allow read, write: if isCompanyMember(companyId);
        }
        match /ccap/{docId} {
          allow read, write: if isCompanyMember(companyId);
        }

        // Associations du métré DXF (par fichier) — document dédié
        match /takeoff/{docId} {
          allow read, write: if isCompanyMember(companyId);
        }
      }

      match /bpu/{itemId} {
        allow read: if isCompanyMember(companyId);
        allow create, update: if isCompanyMember(companyId)
                              && request.resource.data.keys().hasAll(['designation', 'unit', 'price'])
                              && request.resource.data.price is number;
        allow delete: if isCompanyMember(companyId);
      }

      match /categories/{catId} {
        allow read, write: if isCompanyMember(companyId);
      }

      match /units/{unitId} {
        allow read, write: if isCompanyMember(companyId);
      }

      // Blocs — ensembles d'articles BPU (références dynamiques)
      match /blocs/{blocId} {
        allow read, write: if isCompanyMember(companyId);
      }

      match /resources/{resId} {
        allow read, write: if isCompanyMember(companyId);
      }

      // Dossiers de classement des projets
      match /folders/{folderId} {
        allow read, write: if isCompanyMember(companyId);
      }

      // Estimations rapides (esquisse / avant-projet) + modèles utilisateur
      match /quickEstimates/{estimateId} {
        allow read, write: if isCompanyMember(companyId);
      }
      match /estimTemplates/{templateId} {
        allow read, write: if isCompanyMember(companyId);
      }

      // Comptes rendus de chantier (CRC/CRR)
      match /crr/{crrId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyMember(companyId);

        // Logs d'envoi mail — lecture par les membres, écriture par Cloud Function uniquement
        match /emails/{emailId} {
          allow read: if isCompanyMember(companyId);
          allow write: if false;
        }
      }

      // Devis MOE — lecture + écriture par tous les membres
      // (l'accès UI est contrôlé par les permissions par module dans /users/{uid})
      match /devisMoe/{devisId} {
        allow read, write: if isCompanyMember(companyId);
      }

      // Fiches marché (Documents Administratifs)
      match /fichesMarche/{ficheId} {
        allow read, write: if isCompanyMember(companyId);
      }

      // Visites de site
      match /site_visits/{visitId} {
        allow read, write: if isCompanyMember(companyId);
      }

      // ESTIMA TP — études de prix (chiffrage entreprise)
      // L'accès UI est contrôlé par les permissions par module dans /users/{uid}
      match /tpStudies/{studyId} {
        allow read, write: if isCompanyMember(companyId);
      }

      // ESTIMA TP — bibliothèque de ressources réutilisable (MO/matériel/fournitures…)
      match /tpResources/{resId} {
        allow read, write: if isCompanyMember(companyId);
      }

      // Présence en temps réel
      match /presence/{presenceId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyMember(companyId)
                     && request.auth.uid == presenceId;
      }

      // Notes de frais — données ISOLÉES par utilisateur sous /users/{uid}/
      // Chaque user voit uniquement ses propres notes / véhicules / adresses / réglages annuels.
      match /users/{uid}/expenseNotes/{noteId} {
        allow read, write: if isCompanyMember(companyId) && request.auth.uid == uid;
      }
      match /users/{uid}/vehicles/{vehicleId} {
        allow read, write: if isCompanyMember(companyId) && request.auth.uid == uid;
      }
      match /users/{uid}/expenseLocations/{locationId} {
        allow read, write: if isCompanyMember(companyId) && request.auth.uid == uid;
      }
      match /users/{uid}/expenseYearSettings/{year} {
        allow read, write: if isCompanyMember(companyId) && request.auth.uid == uid;
      }

      // Réglages globaux notes de frais (majorations distances) — partagés, admin only
      match /expenseSettings/{docId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyAdmin(companyId);
      }

      // Application super-admin : accès complet sur toute subcollection
      // (suppression cascade d'une entreprise, support, audit cross-tenant)
      match /{document=**} {
        allow read, write: if isAppSuperAdmin();
      }
    }

    // ─── Feedback utilisateurs (/feedback/{id}) — collection GLOBALE ────
    // Collection top-level (hors /companies) pour que le super-admin voie
    // tous les retours d'un coup, toutes entreprises confondues.
    //  - create : tout utilisateur authentifié, pour lui-même uniquement
    //  - read / update / delete : super-admin applicatif uniquement
    match /feedback/{feedbackId} {
      allow create: if request.auth != null
                    && request.resource.data.userUid == request.auth.uid;
      allow read, update, delete: if isAppSuperAdmin();
    }

    // ─── Assistance écran en direct (/supportSessions/{id}) — GLOBALE ───
    // Signalisation WebRTC. Accessible au propriétaire de la session (celui
    // qui partage son écran) ET au super-admin applicatif (le visionneur).
    match /supportSessions/{sessionId} {
      function ownsSession() {
        return request.auth != null
               && resource.data.userUid == request.auth.uid;
      }
      function ownsParentSession() {
        return request.auth != null
               && get(/databases/$(database)/documents/supportSessions/$(sessionId)).data.userUid == request.auth.uid;
      }

      allow create: if request.auth != null
                    && request.resource.data.userUid == request.auth.uid;
      allow read, update, delete: if isAppSuperAdmin() || ownsSession();

      // Candidats ICE (échange réseau WebRTC)
      match /callerCandidates/{cid} {
        allow read, write: if isAppSuperAdmin() || ownsParentSession();
      }
      match /calleeCandidates/{cid} {
        allow read, write: if isAppSuperAdmin() || ownsParentSession();
      }
    }
  }
}
